{
  "ci": {
    "upload": {
      "target": "temporary-public-storage"
    },
    "assert": {
      "assertions": {
        "categories:accessibility": [
          "error",
          {
            "minScore": 0.95
          }
        ],
        "categories:best-practices": [
          "error",
          {
            "minScore": 0.9
          }
        ],
        "categories:seo": [
          "error",
          {
            "minScore": 0.9
          }
        ],
        "categories:performance": [
          "error",
          {
            "minScore": 0.8
          }
        ],
        "errors-in-console": [
          "error",
          {
            "minScore": 1
          }
        ],
        "meta-description": [
          "error",
          {
            "minScore": 1
          }
        ],
        "heading-order": [
          "error",
          {
            "minScore": 1
          }
        ],
        "network-dependency-tree-insight": "off",
        "cache-insight": "off",
        "duplicated-javascript-insight": [
          "warn",
          {
            "minScore": 0.5
          }
        ],
        "legacy-javascript-insight": [
          "warn",
          {
            "minScore": 0.5
          }
        ],
        "uses-long-cache-ttl": [
          "warn",
          {
            "maxLength": 10
          }
        ],
        "unused-javascript": [
          "warn",
          {
            "maxLength": 3
          }
        ],
        "render-blocking-insight": [
          "warn",
          {
            "maxLength": 2
          }
        ],
        "render-blocking-resources": [
          "warn",
          {
            "maxLength": 2
          }
        ]
      }
    }
  }
}
